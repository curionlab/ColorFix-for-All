---
interface Props {
	title: string;
  hideFooter?: boolean;
}

const { title, hideFooter = false } = Astro.props;
---

<!doctype html>
<html lang="ja" class="h-full overflow-hidden">
	<head>
		<meta charset="UTF-8" />
		<meta name="description" content="A tool that proposes minimal color changes to ensure text readability for diverse color vision without destroying the original brand design." />
		<meta name="viewport" content="width=device-width" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<meta name="generator" content={Astro.generator} />
		<title>{title}</title>
	</head>
	<body class="bg-slate-50 text-slate-900 font-sans antialiased h-full flex flex-col overflow-hidden">
    <header class="border-b bg-white flex-shrink-0">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 h-16 flex items-center justify-between">
        <a href={import.meta.env.BASE_URL} class="font-bold text-xl tracking-tight text-emerald-700">ColorFix<span class="text-slate-800"> for All</span></a>
        <nav class="flex gap-4 items-center">
          <a href={import.meta.env.BASE_URL} class="text-sm font-medium text-slate-600 hover:text-emerald-700 transition">案内へ戻る</a>
          <a href={`${import.meta.env.BASE_URL}app`} class="text-sm font-medium bg-emerald-700 text-white px-4 py-2 rounded-md hover:bg-emerald-800 transition shadow-sm">ツールを起動</a>
        </nav>
      </div>
    </header>
		
    <main class="flex-grow flex flex-col overflow-hidden">
      <slot />
    </main>

    {!hideFooter && (
      <footer class="bg-slate-100 border-t py-8 mt-12 flex-shrink-0">
        <div class="max-w-7xl mx-auto px-4 text-center text-slate-500 text-sm">
          &copy; {new Date().getFullYear()} ColorFix for All. Open source project.
        </div>
      </footer>
    )}
	</body>
</html>
